<Window x:Class="Cheese_Quest.LevelComplete"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cheese_Quest"
        mc:Ignorable="d"
        Title="" Height="200" Width="300" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Setting Fon.png"/>
        </Grid.Background>
        <TextBlock Text="Level Completed!" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"/>
        <TextBlock x:Name="TimeText" Text="Time: 00:00" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100,0,0"/>
        <Button  Width="60" Height="40" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="34,0,0,30"
                Click="BackToMenu_Click">
            <StackPanel Orientation="Horizontal">
                <Image Source="Images/Home.png" Width="24" Height="24"/>
            </StackPanel>
        </Button>
        <Button  Width="60" Height="40"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,30,30"
                Click="ContinueButton_Click">
            <StackPanel Orientation="Horizontal">
                <Image Source="Images/Next.png" Width="24" Height="24"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
