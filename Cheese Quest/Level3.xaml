            <Rectangle x:Name="WallCenter" Width="20" Height="316" Fill="Transparent"
      Canvas.Left="194" Canvas.Top="170" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Image x:Name="Cheese1" Source="/Images/cheese.png" Width="28" Height="40" 
Canvas.Left="99" Canvas.Top="297" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
