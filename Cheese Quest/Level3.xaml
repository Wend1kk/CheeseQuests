<Window x:Class="Cheese_Quest.Level3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cheese_Quest"
        mc:Ignorable="d"
        Title="Level3" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Background="#FF3437E2">
        <Canvas x:Name="MyCanvas" Margin="41,48,48,40">
            <Canvas.Background>
                <ImageBrush ImageSource="Images/Level3Fon.png"/>
            </Canvas.Background>
            <Button x:Name="SettingButton" HorizontalAlignment="Left" Height="54" VerticalAlignment="Top" Width="59" Click="SettingButton_Click" Canvas.Left="750" Canvas.Top="450">
