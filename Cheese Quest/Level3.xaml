Canvas.Left="716" Canvas.Top="308" RenderTransformOrigin="0.981,0.513" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="-0.677"/>
                        <RotateTransform Angle="180.915"/>
                        <TranslateTransform Y="-1.045"/>
