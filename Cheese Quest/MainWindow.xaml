<Window x:Class="Cheese_Quest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cheese_Quest"
        mc:Ignorable="d"
        Icon="Icon.ico"
        Title="Cat and Mouse: The Maze Run" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="0,0,0,-40">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF2D49E2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image HorizontalAlignment="Center" Height="300" VerticalAlignment="Top" Width="314" Source="/Images/menuTom.png" RenderTransformOrigin="0.938,0.486" Margin="0,10,0,0"/>
        <Button x:Name="PlayButton" Content="Play" HorizontalAlignment="Center" Height="100" Margin="0,247,0,0" VerticalAlignment="Top" Width="280" FontSize="48" FontFamily="Comic Sans MS" FontStyle="Italic" Click="PlayButton_Click"/>
        <Label Content="Cat and Mouse" HorizontalAlignment="Left" Height="79" Margin="-6,33,0,0" VerticalAlignment="Top" Width="361" RenderTransformOrigin="0.5,0.5" FontFamily="MV Boli" FontSize="48" Foreground="#FFF90D0D">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-20.991"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label Content="The Maze Run" HorizontalAlignment="Left" Height="47" Margin="109,90,0,0" VerticalAlignment="Top" Width="205" RenderTransformOrigin="0.5,0.5" FontFamily="MV Boli" FontSize="24" Foreground="Yellow">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-20.991"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Button x:Name="SettingButton" HorizontalAlignment="Left" Height="72" Margin="400,352,0,0" VerticalAlignment="Top" Width="132" Click="SettingButton_Click">
            <Button.Content>
                <Image Source="Images/seting.png" Height="62"/>
            </Button.Content>
        </Button>
        <Button x:Name="TipsButton" HorizontalAlignment="Left" Height="72" Margin="253,352,0,0" VerticalAlignment="Top" Width="142" Click="TipsButton_Click">
            <Button.Content>
                <Image Source="Images/what.png"/>
            </Button.Content>
        </Button>
        <Button Content="Вийти" HorizontalAlignment="Left" Height="40" Margin="727,6,0,0" VerticalAlignment="Top" Width="43" Click="Button_Click"/>
        <TextBlock x:Name="UsernameTextBlock"
           FontSize="20"
           FontWeight="Bold"
           Margin="0,15,52,0"
           HorizontalAlignment="Right"
           VerticalAlignment="Top"
           Text="..." Width="96" FontFamily="Times New Roman" Foreground="#FFF1E12F" Height="22"/>
        <Canvas Margin="-10,2,10,-2">
            <StackPanel x:Name="CheesePanel" Orientation="Horizontal"/>
            <TextBlock x:Name="CheeseCountText" Text="0000" FontSize="24" Foreground="White" 
 FontWeight="Bold" RenderTransformOrigin="1.712,0.461" Canvas.Left="576" HorizontalAlignment="Left" Canvas.Top="10" VerticalAlignment="Top"/>
            <Image Source="/Images/cheese.png" Width="35" Height="50" RenderTransformOrigin="4.56,0.461" HorizontalAlignment="Left" Canvas.Left="525" VerticalAlignment="Top" Canvas.Top="1"/>
        </Canvas>
    </Grid>
</Window>
