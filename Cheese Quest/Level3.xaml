FontWeight="Bold" HorizontalAlignment="Left" Canvas.Left="746" Canvas.Top="-43" VerticalAlignment="Center" RenderTransformOrigin="0.113,0.534"/>
        </Canvas>
        <Canvas>
            <StackPanel x:Name="CheesePanel" Orientation="Horizontal"/>
            <TextBlock x:Name="CheeseCountText" Text="0000" FontSize="24" Foreground="White" 
  FontWeight="Bold" RenderTransformOrigin="1.712,0.461" Canvas.Left="458" HorizontalAlignment="Left" Canvas.Top="6" VerticalAlignment="Top"/>
            <Image Source="/Images/cheese.png" Width="49" Height="50" RenderTransformOrigin="4.56,0.461" HorizontalAlignment="Center" Canvas.Left="408" VerticalAlignment="Center"/>
