            <Image x:Name="Cheese13" Source="/Images/cheese.png" Width="28" Height="40" 
Canvas.Left="675" Canvas.Top="316" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese14" Source="/Images/cheese.png" Width="28" Height="40" 
Canvas.Left="544" Canvas.Top="316" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="ClockIcon" Source="Images/Timer.png" Width="50" Height="42" HorizontalAlignment="Left" Canvas.Left="684" Canvas.Top="-48" VerticalAlignment="Center"/>
