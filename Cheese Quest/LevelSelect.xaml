<Window x:Class="Cheese_Quest.LevelSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selected Level" Height="459" Width="650" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/Images/Setting Fon.png"/>
    </Window.Background>
    <Canvas Margin="0,0,27,6">

        <Image  Source="Images/LevelSelectFon.png" HorizontalAlignment="Left" Height="400" VerticalAlignment="Center" Width="588" Canvas.Left="35" Canvas.Top="10"/>
        <Button x:Name="Level1" Content="1" Height="44" Canvas.Left="131" Canvas.Top="41" Width="59" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="20" Click="Level1Button_Click"/>
        <Button x:Name="Level2" Content="2" Height="44" Canvas.Left="219" Canvas.Top="63" Width="61" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="20" Click="Level2Button_Click"/>
        <Button x:Name="Level3" Content="3" Height="45" Canvas.Left="479" Canvas.Top="49" Width="61" FontSize="20" Click="Level3_Click"/>
        <Button x:Name="Level7" Content="7" Height="49" Canvas.Left="79" Canvas.Top="194" Width="62" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="20" IsEnabled="False"/>
        <Button x:Name="Level8" Content="8" Height="46" Canvas.Left="46" Canvas.Top="364" Width="66" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20" IsEnabled="False"/>
        <Button x:Name="Level6" Content="6" Height="48" Canvas.Left="316" Canvas.Top="219" Width="65" FontSize="20" IsEnabled="False"/>
        <Button x:Name="Level4" Content="4" Height="46" Canvas.Left="389" Canvas.Top="164" Width="66" FontSize="20" Click="Level4_Click"/>
        <Button x:Name="Level5" Content="5" Height="49" Canvas.Left="527" Canvas.Top="218" Width="63" FontSize="20" IsEnabled="False"/>
        <Button x:Name="Level10" Content="10" Height="45" Canvas.Left="540" Canvas.Top="314" Width="62" FontSize="20" IsEnabled="False"/>
        <Button x:Name="Level9" Content="9" Height="45" Canvas.Left="249" Canvas.Top="323" Width="67" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" IsEnabled="False"/>
        <Button Click="BackButton_Click" Canvas.Left="10" Canvas.Top="13" Height="50" Width="53" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Image Source="Images/Return.png" Width="24" Height="24"/>
        </Button>
    </Canvas>
</Window>
