            <Image x:Name="Cheese7" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="78" Canvas.Top="337" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese8" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="78" Canvas.Top="108" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese9" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="208" Canvas.Top="108" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese10" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="334" Canvas.Top="109" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese11" Source="Images//cheese.png" Width="31" Height="40" 
Canvas.Left="436" Canvas.Top="208" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese12" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="436" Canvas.Top="107" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese13" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="676" Canvas.Top="208" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese14" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="676" Canvas.Top="108" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Trap1" Source="Images/trap.png" Canvas.Left="552" Canvas.Top="208" Tag="Trap" RenderTransformOrigin="0.539,0.667" VerticalAlignment="Top" Height="21" HorizontalAlignment="Center" Width="40"/>
            <Image x:Name="Trap2" Source="Images/Mousetrap.png" Width="60" Height="36" Canvas.Left="334" Canvas.Top="248" Tag="Trap" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Trap3" Source="Images/Mousetrap.png" Width="48" Height="35" Canvas.Left="93" Canvas.Top="193" HorizontalAlignment="Left" VerticalAlignment="Center" Tag="Trap"/>
            <Image x:Name="Hole1" Source="Images/Teleport.png" Width="24" Height="22" Canvas.Left="238" Canvas.Top="257" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.48,-0.482"/>
            <Image x:Name="Hole2" Source="Images/Teleport.png" Width="24" Height="26" Canvas.Left="486" Canvas.Top="50" RenderTransformOrigin="0.5,0.168" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Canvas>
        <Canvas>
            <StackPanel x:Name="CheesePanel" Orientation="Horizontal"/>
            <TextBlock x:Name="CheeseCountText" Text="0000" FontSize="24" Foreground="White" 
         FontWeight="Bold" RenderTransformOrigin="1.712,0.461" Canvas.Left="458" HorizontalAlignment="Left" Canvas.Top="6" VerticalAlignment="Top"/>
            <Image Source="/Images/cheese.png" Width="50" Height="50" RenderTransformOrigin="4.56,0.461" HorizontalAlignment="Left" Canvas.Left="407" VerticalAlignment="Top"/>
