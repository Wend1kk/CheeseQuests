Canvas.Left="544" Canvas.Top="12" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="WallLeft" Width="136" Height="23" Fill="Transparent"
    Canvas.Left="510" Canvas.Top="248" HorizontalAlignment="Left" VerticalAlignment="Center"/>
