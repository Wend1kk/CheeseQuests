<Window x:Class="Cheese_Quest.Level2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cheese_Quest"
        mc:Ignorable="d"
        Title="Level2" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Background="#FF3F42FF">
        <Canvas x:Name="MyCanvas" Margin="41,48,48,40">
            <Canvas.Background>
                <ImageBrush ImageSource="/Images/Level2Fon.png"/>
            </Canvas.Background>
            <Button x:Name="SettingButton" HorizontalAlignment="Left" Height="54" VerticalAlignment="Top" Width="59" Click="SettingButton_Click" Canvas.Left="750" Canvas.Top="450">
                <Button.Content>
                    <Image Source="Images/seting.png" Height="51"/>
                </Button.Content>
            </Button>
            <Rectangle x:Name="TopBorder" Width="800" Height="5" Fill="Transparent" 
Canvas.Left="1" Canvas.Top="45" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="BottomBorder" Width="800" Height="10" Fill="Transparent" 
    Canvas.Left="35" Canvas.Top="417" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="RightBorder" Width="10" Height="450" Fill="Transparent" 
     Canvas.Left="755" Canvas.Top="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Rectangle x:Name="LeftBorder" Width="10" Height="450" Fill="Transparent" 
    Canvas.Left="35" Canvas.Top="0"/>
            <Rectangle x:Name="Shelf2" Width="40" Height="92" Fill="Transparent"
    Canvas.Left="740" Canvas.Top="294" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle x:Name="Shelf" Width="107" Height="80" Fill="Transparent"
   Canvas.Left="364" Canvas.Top="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Rectangle x:Name="WallLeft" Width="307" Height="8" Fill="Transparent"
    Canvas.Left="10" Canvas.Top="249" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="WallCenter" Width="20" Height="200" Fill="Transparent"
   Canvas.Left="294" Canvas.Top="271" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="MouseImage" Source="Images/mouse.png" Width="38" Height="43" Canvas.Left="545" Canvas.Top="273" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Image x:Name="DoorImage" Source="Images/Door.png" Width="22" Height="25"
Canvas.Left="32" Canvas.Top="160" RenderTransformOrigin="0.981,0.513" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="-0.677"/>
                        <RotateTransform/>
                        <TranslateTransform Y="-1.045"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>
            <Image x:Name="ClockIcon" Source="Images/Timer.png" Width="50" Height="42" HorizontalAlignment="Left" Canvas.Left="684" Canvas.Top="-48" VerticalAlignment="Center"/>
            <TextBlock x:Name="TimerText" Text="02:00" FontSize="24" Foreground="White" 
    FontWeight="Bold" HorizontalAlignment="Left" Canvas.Left="746" Canvas.Top="-43" VerticalAlignment="Center" RenderTransformOrigin="0.113,0.534"/>
            <Image x:Name="Cheese1" Source="/Images/cheese.png" Width="28" Height="40" 
Canvas.Left="558" Canvas.Top="108" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese2" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="676" Canvas.Top="337" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese3" Source="Images/cheese.png" Width="31" Height="40" 
Canvas.Left="556" Canvas.Top="337" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese4" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="334" Canvas.Top="337" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese5" Source="/Images/cheese.png" Width="31" Height="40" 
Canvas.Left="436" Canvas.Top="337" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese6" Source="/Images/cheese.png" Width="31" Height="40" 
