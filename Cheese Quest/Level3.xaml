        <Button Click="BackButton_Click" Margin="10,497,817,10">
            <StackPanel Orientation="Horizontal">
                <Image Source="Images/Return.png" Width="24" Height="24"/>
            </StackPanel>
        </Button>
        <Canvas>
            <Image Name="Heart1" Source="Images/Live.png" Width="40" Height="40" HorizontalAlignment="Left" Canvas.Left="41" VerticalAlignment="Top" Canvas.Top="10" />
