<Window x:Class="Cheese_Quest.Level1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cheese_Quest"
        mc:Ignorable="d"
        Title="Level1" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Background="#FF3437E2">
        <Canvas x:Name="MyCanvas" Margin="41,48,48,40">
            <Canvas.Background>
                <ImageBrush ImageSource="/Images/LevelFon.png"/>
            </Canvas.Background>
            <Button x:Name="SettingButton" HorizontalAlignment="Left" Height="54" VerticalAlignment="Top" Width="59" Click="SettingButton_Click" Canvas.Left="750" Canvas.Top="450">
                <Button.Content>
                    <Image Source="Images/seting.png" Height="51"/>
                </Button.Content>
            </Button>
            <Rectangle x:Name="TopBorder" Width="800" Height="10" Fill="Transparent" 
               Canvas.Left="1" Canvas.Top="40" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="BottomBorder" Width="800" Height="10" Fill="Transparent" 
               Canvas.Left="35" Canvas.Top="417" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="LeftBorder" Width="12" Height="450" Fill="Transparent" 
               Canvas.Left="35" Canvas.Top="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Rectangle x:Name="RightBorder" Width="10" Height="450" Fill="Transparent" 
               Canvas.Left="755" Canvas.Top="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Image x:Name="MouseImage" Source="/Images/Mouse.png" Width="53" Height="43" Canvas.Left="657" Canvas.Top="220" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="Table" Width="71" Height="24" Fill="Transparent"
               Canvas.Left="171" Canvas.Top="266" HorizontalAlignment="Center" VerticalAlignment="Top" RadiusX="2.447" RadiusY="2.447"/>
            <Rectangle x:Name="Shelf" Width="38" Height="80" Fill="Transparent"
               Canvas.Left="755" Canvas.Top="68" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle x:Name="Shelf2" Width="41" Height="92" Fill="Transparent"
                Canvas.Left="35" Canvas.Top="371" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="WallLeft" Width="164" Height="23" Fill="Transparent"
               Canvas.Left="150" Canvas.Top="248" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle x:Name="WallRight" Width="14" Height="249" Fill="Transparent"
               Canvas.Left="587" Canvas.Top="190" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="0.095"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle x:Name="WallCenter" Width="20" Height="200" Fill="Transparent"
               Canvas.Left="294" Canvas.Top="271" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese1" Source="/Images/cheese.png" Width="40" Height="40" 
           Canvas.Left="568" Canvas.Top="108" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.538,1.226"/>
            <Image x:Name="Cheese3" Source="/Images/cheese.png" Width="28" Height="40" 
           Canvas.Left="356" Canvas.Top="351" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese4" Source="/Images/cheese.png" Width="40" Height="40" 
           Canvas.Left="668" Canvas.Top="351" RenderTransformOrigin="1.863,0.268" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese5" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="663" Canvas.Top="108" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese6" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="294" Canvas.Top="108" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.35,1.226"/>
            <Image x:Name="Cheese7" Source="/Images/cheese.png" Width="29" Height="40" 
                Canvas.Left="444" Canvas.Top="271" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese8" Source="/Images/cheese.png" Width="29" Height="40" 
                Canvas.Left="532" Canvas.Top="271" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese9" Source="/Images/cheese.png" Width="30" Height="40" 
                Canvas.Left="445" Canvas.Top="351" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese10" Source="/Images/cheese.png" Width="30" Height="40" 
                Canvas.Left="531" Canvas.Top="351" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese11" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="192" Canvas.Top="108" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Image x:Name="Cheese12" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="83" Canvas.Top="205" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese13" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="177" Canvas.Top="351" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese14" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="445" Canvas.Top="108" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese15" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="83" Canvas.Top="108" HorizontalAlignment="Center" VerticalAlignment="Top" RenderTransformOrigin="0.462,1.488"/>
            <Image x:Name="Cheese16" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="93" Canvas.Top="300" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="Cheese2" Source="/Images/cheese.png" Width="40" Height="40" 
                Canvas.Left="356" Canvas.Top="271" RenderTransformOrigin="0.538,1.226" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </Canvas>
        <Canvas>
            <StackPanel x:Name="CheesePanel" Orientation="Horizontal"/>
            <TextBlock x:Name="CheeseCountText" Text="0000" FontSize="24" Foreground="White" 
                FontWeight="Bold" RenderTransformOrigin="1.712,0.461" Canvas.Left="458" HorizontalAlignment="Left" Canvas.Top="6" VerticalAlignment="Top"/>
            <Image Source="/Images/cheese.png" Width="50" Height="50" RenderTransformOrigin="4.56,0.461" HorizontalAlignment="Left" Canvas.Left="407" VerticalAlignment="Top"/>
        </Canvas>
        <Canvas>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>
            <Image x:Name="ClockIcon" Source="Images/Timer.png" Width="50" Height="42" HorizontalAlignment="Left" Canvas.Left="724" Canvas.Top="1" VerticalAlignment="Top"/>
            <TextBlock x:Name="TimerText" Text="02:00" FontSize="24" Foreground="White" 
               FontWeight="Bold" HorizontalAlignment="Left" Canvas.Left="784" Canvas.Top="6" VerticalAlignment="Center" RenderTransformOrigin="0.113,0.534"/>
            <Image x:Name="DoorImage" Source="/Images/Door.png" Width="29" Height="25"
       Canvas.Left="63" Canvas.Top="317" RenderTransformOrigin="1.134,0.519" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="-0.054"/>
                        <RotateTransform/>
                        <TranslateTransform Y="-0.34"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Canvas>
        <Button Click="BackButton_Click" Margin="10,497,817,10">
            <StackPanel Orientation="Horizontal">
                <Image Source="Images/Return.png" Width="24" Height="24"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
